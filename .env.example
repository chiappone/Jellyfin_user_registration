# Jellyfin connection
JELLYFIN_API_KEY=your_api_key_here
JELLYFIN_URL=http://localhost:8096
JELLYFIN_PUBLIC_URL=

# Server display name (shown on Join page and admin header)
SERVER_NAME=Jellyfin

# Admin password (SHA-256 hash)
# Generate with: python3 -c "import hashlib; print(hashlib.sha256(b'your_password').hexdigest())"
ADMIN_PASSWORD_HASH=your_hash_here

# Optional: comma-separated list of library names to grant access to (empty = all)
DEFAULT_LIBRARIES=
